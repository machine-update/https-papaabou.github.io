# Surface split by Vercel project
# Public project  -> APP_SURFACE=public
# Admin project   -> APP_SURFACE=admin
APP_SURFACE=public

# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
PAYLOAD_SECRET=change-me-long-random-secret
NEXTAUTH_SECRET=change-me-long-random-secret
CRON_SECRET=change-me-long-random-secret
PREVIEW_SECRET=change-me-long-random-secret

# Public URL for this specific Vercel project
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
NEXT_PUBLIC_SERVER_URL=https://your-project.vercel.app

# Optional anti-bot protection (Cloudflare Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA...
TURNSTILE_SECRET_KEY=0x4AAAA...-secret

# Optional (contact/casting forms)
RESEND_API_KEY=re_xxxxxxxxx
CONTACT_TO_EMAIL=hello@xksprod.com
CONTACT_FROM_EMAIL=XKSPROD <noreply@your-domain.com>
