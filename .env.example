# Runtime surface for split deployments
# public -> public website only
# admin  -> admin application only
APP_SURFACE=public

# Canonical app URL for the current surface (public/admin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database connection string (production should use managed PostgreSQL)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/xksprod

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE

# Existing Payload URL setting (kept for compatibility)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Optional anti-bot protection (Cloudflare Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Contact form email delivery (Resend)
RESEND_API_KEY=re_xxxxxxxxx
CONTACT_TO_EMAIL=hello@xksprod.com
CONTACT_FROM_EMAIL="XKSPROD <onboarding@resend.dev>"

# Legacy admin custom backend env vars (optional)
ADMIN_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/xksprod_admin
ADMIN_JWT_SECRET=CHANGE_ME_SUPER_SECRET
